{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ../scripts/verify-public-assets.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:local:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:local:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:local:setup": "npm run db:local:generate && npm run db:local:push",
    "db:prod:generate": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.4.2",
    "next": "15.5.18",
    "postcss": "^8.5.6",
    "prisma": "^6.19.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "typescript": "^5"
  }
}
